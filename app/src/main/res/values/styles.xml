<resources>
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">#3498DB</item>
        <item name="colorPrimaryDark">#1B263B</item>
        <item name="colorAccent">#2ECC71</item>
    </style>

    <style name="RoundedButton">
        <item name="android:backgroundTint">@color/colorPrimary</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:padding">14dp</item>
        <item name="android:layout_marginTop">12dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="RoundedEditText">
        <item name="android:background">@drawable/rounded_edittext</item>
        <item name="android:padding">14dp</item>
        <item name="android:textColor">#000</item>
        <item name="android:layout_marginTop">12dp</item>
    </style>
</resources>